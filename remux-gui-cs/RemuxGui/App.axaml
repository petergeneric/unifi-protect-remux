<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RemuxGui.App"
             Name="UBV Remux"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppWindowBackground" Color="#1E2030" />
                    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="#272A3C" />
                    <SolidColorBrush x:Key="SystemControlBackgroundBaseLowBrush" Color="#232536" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppWindowBackground" Color="#F3F3F3" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="NavActiveBg" Color="#266C8CFF" />
            <SolidColorBrush x:Key="NavActiveFg" Color="#6C8CFF" />
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />

        <!-- Override Fluent dark mode background (avoid near-black) -->
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource AppWindowBackground}" />
        </Style>

        <!-- Nav item button style (always on dark sidebar) -->
        <Style Selector="Button.nav-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#A8ADBC" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                    <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="Foreground" Value="#DDE0E8" />
        </Style>
        <Style Selector="Button.nav-item:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="Foreground" Value="#DDE0E8" />
            <Setter Property="RenderTransform" Value="none" />
        </Style>

        <!-- Subtle button style for tertiary actions -->
        <Style Selector="Button.subtle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </Style>
        <Style Selector="Button.subtle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <!-- Animated view transition style -->
        <Style Selector="UserControl.animated-view">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Filter pill transitions -->
        <Style Selector="Button.filter-pill">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                    <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
    </Application.Styles>
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About UBV Remux" Click="OnNativeAboutClick" />
            <NativeMenuItemSeparator />
        </NativeMenu>
    </NativeMenu.Menu>
</Application>
